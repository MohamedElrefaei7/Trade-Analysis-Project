    {
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "description": "Latest absolute z-score across all features — tail-risk snapshot.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "z_score"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "date"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "abs_z"
          }
        ]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n    SELECT feature_name, MAX(date) AS last_date\n    FROM features\n    WHERE z_score IS NOT NULL\n    GROUP BY feature_name\n)\nSELECT f.feature_name,\n       f.date::timestamp AS date,\n       f.value,\n       f.z_score,\n       ABS(f.z_score) AS abs_z\nFROM features f\nJOIN latest l\n  ON l.feature_name = f.feature_name\n AND l.last_date    = f.date\nORDER BY ABS(f.z_score) DESC NULLS LAST;",
          "refId": "A"
        }
      ],
      "title": "Latest Z-Scores (all features)",
      "type": "table"
    }
