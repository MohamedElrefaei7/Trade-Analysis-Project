          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date AS time,\n       feature_name AS metric,\n       z_score AS value\nFROM features\nWHERE feature_name IN ($features)\n  AND date >= NOW() - ($lookback)::interval\n  AND z_score IS NOT NULL\nORDER BY date;",
